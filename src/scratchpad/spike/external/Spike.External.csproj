<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>RoyalCode.Extensions.SourceGenerator</AssemblyName>
    <RootNamespace>RoyalCode.Extensions.SourceGenerator</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RoslynVersion Condition="'$(RoslynVersion)' == ''">4.8.0</RoslynVersion>
    <RoslynLabel Condition="'$(RoslynLabel)' == ''">roslyn4.8</RoslynLabel>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\..\..\..\Utils\RoyalCode.Utils\RoyalCode.Extensions.SourceGenerator\*.cs" />
    <Compile Include="..\..\..\..\..\Utils\RoyalCode.Utils\RoyalCode.Extensions.SourceGenerator\Descriptors\**\*.cs" />
    <Compile Include="..\..\..\..\..\Utils\RoyalCode.Utils\RoyalCode.Extensions.SourceGenerator\Generators\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="$(RoslynVersion)" PrivateAssets="all" />
  </ItemGroup>
</Project>
